<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Soulitek AIO Scripts"
        Height="900" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0F1419"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <!-- New Color System -->
            <SolidColorBrush x:Key="PrimaryBrush"          Color="#6366F1"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush"      Color="#4F46E5"/>
            <SolidColorBrush x:Key="AccentBrush"            Color="#00E5FF"/>
            <SolidColorBrush x:Key="BackgroundDarkBrush"    Color="#0F1419"/>
            <SolidColorBrush x:Key="BackgroundLightBrush"   Color="#F8FAFC"/>
            <SolidColorBrush x:Key="SidebarBrush"           Color="#131920"/>
            <SolidColorBrush x:Key="CardDarkBrush"          Color="#1A1F2E"/>
            <SolidColorBrush x:Key="CardLightBrush"         Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardHoverBrush"         Color="#2A2F3E"/>
            <SolidColorBrush x:Key="TextPrimaryDarkBrush"   Color="#F1F5F9"/>
            <SolidColorBrush x:Key="TextPrimaryLightBrush"  Color="#0F172A"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"     Color="#A0A9B8"/>
            <!-- Legacy Zinc aliases preserved for Apply-Theme FindResource calls -->
            <SolidColorBrush x:Key="WhiteBrush"    Color="White"/>
            <SolidColorBrush x:Key="Zinc800Brush"  Color="#1A1F2E"/>
            <SolidColorBrush x:Key="Zinc700Brush"  Color="#252B3B"/>
            <SolidColorBrush x:Key="Zinc500Brush"  Color="#A0A9B8"/>
            <SolidColorBrush x:Key="Zinc400Brush"  Color="#A0A9B8"/>
            <SolidColorBrush x:Key="Zinc300Brush"  Color="#CBD5E1"/>
            <SolidColorBrush x:Key="Zinc200Brush"  Color="#E2E8F0"/>
            <SolidColorBrush x:Key="Zinc100Brush"  Color="#F1F5F9"/>
            <SolidColorBrush x:Key="Zinc900Brush"  Color="#0F1419"/>

            <!-- Tool Card Style -->
            <Style x:Key="ToolCard" TargetType="Border">
                <Setter Property="Background" Value="#1A1F2E"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="0" Opacity="0.15"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#6366F1" BlurRadius="16" ShadowDepth="0" Opacity="0.3"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Search Box Style -->
            <Style x:Key="SearchBox" TargetType="TextBox">
                <Setter Property="Background" Value="#1A1F2E"/>
                <Setter Property="BorderBrush" Value="#252B3B"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="#F1F5F9"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="40,10,16,10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                Margin="40,0,0,0"
                                                VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE721;"
                                             FontFamily="Segoe MDL2 Assets"
                                             FontSize="14"
                                             VerticalAlignment="Center"
                                             Margin="12,0,0,0"
                                             Foreground="#A0A9B8"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="#6366F1"/>
                        <Setter Property="Background" Value="#1E243A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Navigation Button Style (kept for compatibility) -->
            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.7"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Main Container: 3 rows × 2 columns -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header: spans both columns -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="#131920" Name="TitleBarGrid" Height="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo (left, col 0) -->
            <Button Grid.Column="0" Name="LogoButton" HorizontalAlignment="Left"
                    VerticalAlignment="Center" Background="Transparent"
                    BorderThickness="0" Padding="16,0,0,0" Cursor="Hand"
                    ToolTip="Visit Soulitek website">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter Content="{TemplateBinding Content}"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <Image Name="LogoImage" Width="160" Height="36" Stretch="Uniform"/>
            </Button>

            <!-- Search (center, col 1) -->
            <Grid Grid.Column="1" Margin="24,0,24,0" VerticalAlignment="Center">
                <TextBox Name="SearchBox" Style="{StaticResource SearchBox}"
                         VerticalAlignment="Center" MaxWidth="600"/>
                <TextBlock Name="SearchPlaceholder" Text="Search tools...  Ctrl+K"
                           FontSize="13" FontFamily="Segoe UI" Foreground="#A0A9B8"
                           VerticalAlignment="Center" Margin="40,0,0,0"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- Window controls (right, col 2) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">
                <Button Name="ThemeToggleButton" Width="40" Height="40"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        ToolTip="Toggle theme">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Name="ThemeIcon" Foreground="#A0A9B8"/>
                </Button>
                <Button Name="MinimizeButton" Width="40" Height="40"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Text="&#xE921;" Foreground="#A0A9B8"/>
                </Button>
                <Button Name="CloseButton" Width="40" Height="40"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Text="&#xE8BB;" Foreground="#A0A9B8"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Sidebar (row 1, col 0) -->
        <Grid Grid.Row="1" Grid.Column="0" Background="#131920" Name="SidebarGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Name="SidebarCategoriesPanel" Margin="0,16,0,0"/>
            <StackPanel Grid.Row="1" Name="SidebarNavPanel" Margin="0,0,0,8"/>
        </Grid>

        <!-- Main content (row 1, col 1) -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                     Name="MainScrollViewer"
                     VerticalScrollBarVisibility="Auto"
                     Background="#0F1419">
            <WrapPanel Name="ToolsPanel" Orientation="Horizontal" Margin="16,16,16,16"/>
        </ScrollViewer>

        <!-- Footer: spans both columns -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Name="FooterGrid"
                Background="#0F1419"
                BorderBrush="#1A1F2E" BorderThickness="0,1,0,0">
            <TextBlock Name="StatusLabel"
                      Text="Ready"
                      FontSize="11"
                      FontFamily="Segoe UI"
                      Foreground="#A0A9B8"
                      HorizontalAlignment="Left"
                      Margin="16,6,0,6"/>
        </Border>

        <!-- Toast notification overlay (row 1, col 1) -->
        <Border Name="ToastBorder" Grid.Row="1" Grid.Column="1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,24,24" Background="#1A1F2E" CornerRadius="10"
                Padding="16,10,16,10" Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel Orientation="Horizontal">
                <TextBlock Name="ToastIcon" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Name="ToastText" FontSize="13" FontFamily="Segoe UI"
                           Foreground="#F1F5F9" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
